# ─── NakaNomad API — Environment Variables ───────────────────────────────────
# Copy to .env and fill in your values

# ─── Lightning Backend ────────────────────────────────────────────────────────
# Choose one:

# Option A: Alby (easiest — https://getalby.com)
ALBY_API_KEY=

# Option B: LNbits (self-hosted)
LIGHTNING_BACKEND=lnbits
LNBITS_URL=https://your-lnbits.com
LNBITS_INVOICE_KEY=

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
L402_SECRET=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ─── Development ─────────────────────────────────────────────────────────────
# Set to true to skip Lightning payments (FREE, for local dev only)
DEV_MODE=false
